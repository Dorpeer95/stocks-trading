# ============================================================
# stocks-agent environment variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Supabase (required) ---
STOCKS_SUPABASE_URL=https://your-project.supabase.co
STOCKS_SUPABASE_KEY=your-service-role-key-here

# --- Telegram (required) ---
STOCKS_TELEGRAM_TOKEN=your-telegram-bot-token
STOCKS_TELEGRAM_CHAT_ID=your-stocks-chat-id

# --- OpenAI (required for GPT features) ---
STOCKS_OPENAI_API_KEY=sk-your-openai-key

# --- News & Data APIs (optional but recommended) ---
STOCKS_NEWSAPI_KEY=your-newsapi-key
STOCKS_ALPHA_VANTAGE_KEY=your-alpha-vantage-key

# --- Portfolio Configuration ---
STOCKS_PORTFOLIO_VALUE=10000
STOCKS_RISK_PER_TRADE=0.02
STOCKS_MAX_POSITION_PCT=0.25
STOCKS_CASH_RESERVE_PCT=0.10
STOCKS_MAX_POSITIONS=8
STOCKS_MAX_HOLD_DAYS=42
STOCKS_TRAILING_ATR_MULT=2.0

# --- Feature Flags ---
STOCKS_ENABLE_ML=true
STOCKS_ENABLE_GPT=true
STOCKS_ENABLE_NEWS=true
STOCKS_ENABLE_INSIDER=true
STOCKS_ENABLE_EARNINGS=true
STOCKS_DRY_RUN=false

# --- Scanner Thresholds ---
STOCKS_MIN_ADX=20
STOCKS_MIN_RS_PERCENTILE=50
STOCKS_MAX_ATR_PCT=8
STOCKS_MIN_VOLUME_RATIO=0.5
STOCKS_TOP_CANDIDATES=30
STOCKS_ENABLE_ML_FILTER=true
STOCKS_ML_DIRECTION_THRESHOLD=0.45

# --- Scorer Weights (must sum to 1.0 when ML is off) ---
STOCKS_W_TECHNICAL=0.35
STOCKS_W_RS=0.25
STOCKS_W_FUNDAMENTAL=0.15
STOCKS_W_SENTIMENT=0.10
STOCKS_W_INSIDER=0.10
STOCKS_W_MACRO=0.05
STOCKS_W_ML=0.15
STOCKS_MIN_CONFIDENCE=60

# --- GPT Cost Controls ---
STOCKS_GPT_MONTHLY_BUDGET=5.00
STOCKS_GPT_KILL_SWITCH=4.00

# --- Environment ---
STOCKS_ENV=production
STOCKS_LOG_LEVEL=INFO
STOCKS_HEALTH_PORT=8001

# Alpaca credentials
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
